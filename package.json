{
  "name": "@imgwire/codegen-core",
  "version": "0.1.0",
  "description": "Deterministic OpenAPI shaping pipeline for imgwire SDKs.",
  "license": "UNLICENSED",
  "packageManager": "yarn@1.19.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write .",
    "test": "yarn build && node --test dist/tests/**/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
