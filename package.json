{
  "name": "@imgwire/codegen-core",
  "version": "0.1.3",
  "description": "Deterministic OpenAPI shaping pipeline for imgwire SDKs.",
  "license": "MIT",
  "packageManager": "yarn@1.19.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "restricted"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist dist-tests && tsc -p tsconfig.build.json",
    "format": "prettier --write .",
    "prepack": "yarn build",
    "release:prepare": "node scripts/release.mjs prepare",
    "release:verify-tag": "node scripts/release.mjs verify-tag",
    "test": "yarn build && tsc -p tsconfig.test.json && node --test dist-tests/tests/**/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
